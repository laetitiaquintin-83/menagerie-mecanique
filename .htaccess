# 1. Empêcher de lister les fichiers du dossier
Options -Indexes

# 2. Bloquer l'accès direct aux fichiers sensibles
<FilesMatch "\.(php|sql|env|git)$">
    # On autorise uniquement les pages que l'utilisateur doit voir
    # On bloque spécifiquement les fichiers de config
    <Files "config.php">
        Deny from all
    </Files>
    <Files "connexion.php">
        Deny from all
    </Files>
    <Files "auth.php">
        Deny from all
    </Files>
</FilesMatch>

# 3. Sécurité pour les suppressions (bloque le GET)
<Files "delete.php">
    <Limit GET>
        Deny from all
    </Limit>
</Files>

<Files "delete_commande.php">
    <Limit GET>
        Deny from all
    </Limit>
</Files>